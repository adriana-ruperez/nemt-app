rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Rider profile document: users/{uid}
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rides: riders can only access their own documents
    match /rides/{rideId} {
      allow read: if request.auth != null
        && resource.data.riderUid == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /conversations/{conversationId} {
      allow read: if request.auth != null
        && (
          resource.data.riderUid == request.auth.uid
          || request.auth.uid in resource.data.participantIds
        );
      allow create: if false;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participantIds
        && request.resource.data.riderUid == resource.data.riderUid
        && request.resource.data.type == resource.data.type
        && request.resource.data.participantIds == resource.data.participantIds;
      allow delete: if false;
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      allow create: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
        && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
